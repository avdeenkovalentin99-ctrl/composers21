{
  "name": "composersxxi",
  "version": "1.0.0",
  "description": "Festival website scaffold",
  "scripts": {
    "dev": "vite",
    "fix:utf8": "tsc ./scripts/fix-utf8.ts --module NodeNext --target ES2022 --outDir .tmp-build --skipLibCheck --ignoreConfig && node ./.tmp-build/fix-utf8.js",
    "check:utf8": "tsc ./scripts/check-utf8.ts --module NodeNext --target ES2022 --outDir .tmp-build --skipLibCheck --ignoreConfig && node ./.tmp-build/check-utf8.js",
    "build:bios": "npm run fix:utf8 && npm run check:utf8 && tsc ./scripts/build-bios.ts --module NodeNext --target ES2022 --outDir .tmp-build --skipLibCheck --ignoreConfig && node ./.tmp-build/build-bios.js",
    "build": "npm run fix:utf8 && npm run check:utf8 && tsc -b && vite build",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
